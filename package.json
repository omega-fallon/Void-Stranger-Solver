{
  "name": "void_stranger_brand_solver",
  "version": "1.0.0",
  "main": "dist/index.js",
  "bin": {
    "void-stranger-brand-solver": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "node --max_old_space_size=16384 -r ts-node/register src/index.ts",
    "start": "node dist/index.js",
    "solve": "ts-node src/solve.ts",
    "test": "node --require ts-node/register --test src/tests/*.test.ts",
    "test:watch": "node --require ts-node/register --test --watch src/tests/*.test.ts",
    "test:coverage": "c8 --reporter=lcov --reporter=text node --require ts-node/register --test src/tests/*.test.ts",
    "perf": "node --cpu-prof --cpu-prof-dir=profiles -r ts-node/register src/index.ts"
  },
  "c8": {
    "include": [
      "src/**/*.ts"
    ],
    "exclude": [
      "src/**/*.test.ts",
      "src/tests/**"
    ],
    "extension": [
      ".ts"
    ],
    "all": true,
    "src": "src"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@types/node": "^25.9.1",
    "c8": "^11.0.0",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3"
  }
}
